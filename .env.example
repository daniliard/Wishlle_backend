APP_PUBLIC_URL=https://wishlle-4isp.vercel.app
APP_ENV=development

# Directus
DIRECTUS_URL=https://directus.up.railway.app
DIRECTUS_TOKEN=token
DIRECTUS_TIMEOUT=15.0

# Назви колекцій
DIRECTUS_USERS_COLLECTION=users
DIRECTUS_EVENTS_COLLECTION=events
DIRECTUS_WISHES_COLLECTION=wish_lists
DIRECTUS_WISH_ITEMS_COLLECTION=wish_items
DIRECTUS_NOTIFICATIONS_COLLECTION=notifications

# Назви полів
DIRECTUS_USERS_TELEGRAM_FIELD=telegram_id
DIRECTUS_USERS_LOCALE_FIELD=language
DIRECTUS_EVENTS_OWNER_FIELD=owner_id
DIRECTUS_EVENTS_DATE_FIELD=event_date
DIRECTUS_EVENTS_TITLE_FIELD=title
DIRECTUS_WISHES_OWNER_FIELD=owner_id
DIRECTUS_WISHES_TITLE_FIELD=title
DIRECTUS_WISHES_CREATED_FIELD=date_created
DIRECTUS_NOTIFICATIONS_USER_FIELD=recipient_id
DIRECTUS_NOTIFICATIONS_EVENT_FIELD=related_id
DIRECTUS_NOTIFICATIONS_DAYS_FIELD=type

# Telegram
TELEGRAM_BOT_TOKEN=123456789:AAEhBOweik6ad9r_FFFFFFFFFFFFFFFFFFFFFFF
TELEGRAM_BOT_USERNAME=Wishlle_bot
TELEGRAM_CLIENT_ID=8624605092
TELEGRAM_CLIENT_SECRET=client-secret-from-botfather
TELEGRAM_REDIRECT_URI=https://wishlle-4isp.vercel.app/auth/callback

# Google OAuth
GOOGLE_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# JWT
JWT_SECRET=random-string-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=10080

# Parser
PARSER_TIMEOUT_SECONDS=10.0
PARSER_USER_AGENT=WishlleBot/1.0 (+https://wishlle.app)

# Notifier
NOTIFIER_CRON_HOUR=9
NOTIFIER_CRON_MINUTE=0
NOTIFIER_TIMEZONE=Europe/Kyiv
NOTIFIER_REMINDER_DAYS=[7,3,1,0]
NOTIFIER_WISHES_ENABLED=true
NOTIFIER_WISHES_LOOKBACK_HOURS=24

CORS_ORIGINS=["http://localhost:5173","https://wishlle.vercel.app"]
